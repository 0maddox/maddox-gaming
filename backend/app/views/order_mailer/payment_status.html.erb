<p>Hello <%= @user.username.presence || @user.name.presence || 'player' %>,</p>

<p>Your Maddox Gaming order #<%= @order.id %> is now <strong><%= @order.status %></strong>.</p>

<ul>
  <li>Amount: <%= @order.currency %> <%= format('%.2f', @order.total_amount.to_f) %></li>
  <li>Payment method: <%= @order.payment_method %></li>
  <li>Gateway: <%= @order.gateway_name %></li>
  <li>Reference: <%= @order.payment_reference %></li>
  <li>Transaction ID: <%= @order.transaction_id.presence || 'Pending confirmation' %></li>
</ul>

<% if @order.paid? %>
  <p>Thank you for your purchase.</p>
<% else %>
  <p>Your payment did not complete successfully. Return to checkout to retry.</p>
<% end %>
